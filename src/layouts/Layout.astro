---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "K-12 Systems Literacy Curriculum" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} | Lesson Hub</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <style is:global>
    :root {
      --bg: #0a0a0a;
      --bg-elevated: #111111;
      --bg-hover: #1a1a1a;
      --fg: #f5f5f5;
      --fg-muted: #888888;
      --accent: #00d9ff;
      --accent-2: #00ff88;
      --accent-warm: #ff3c00;
      --border: #222222;
      --radius: 12px;
      --transition: 0.2s ease;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
    }
    
    body {
      min-height: 100vh;
    }
    
    a {
      color: var(--accent);
      text-decoration: none;
      transition: color var(--transition);
    }
    
    a:hover {
      color: var(--accent-2);
    }
    
    h1, h2, h3, h4 {
      font-weight: 600;
      line-height: 1.2;
    }
    
    h1 { font-size: 3rem; }
    h2 { font-size: 2rem; }
    h3 { font-size: 1.5rem; }
    
    code, pre {
      font-family: 'JetBrains Mono', monospace;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }
    
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: var(--accent);
      color: var(--bg);
      border-radius: var(--radius);
      font-weight: 600;
      transition: all var(--transition);
    }
    
    .btn:hover {
      background: var(--accent-2);
      transform: translateY(-2px);
    }
    
    .btn-secondary {
      background: transparent;
      border: 2px solid var(--accent);
      color: var(--accent);
    }
    
    .btn-secondary:hover {
      background: var(--accent);
      color: var(--bg);
    }
  </style>
</head>

<body>
  <nav class="site-nav">
    <div class="container nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🌱</span>
        <span class="logo-text">Lesson Hub</span>
      </a>
      
      <div class="nav-links">
        <a href="/lessons">Lessons</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/about">About</a>
      </div>
    </div>
  </nav>
  
  <slot />
  
  <footer class="site-footer">
    <div class="container">
      <p>🎓 Systems Literacy Curriculum — Built with AI agents</p>
    </div>
  </footer>
</body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .nav-links {
    display: flex;
    gap: 30px;
  }
  
  .nav-links a {
    color: var(--fg-muted);
    font-weight: 500;
  }
  
  .nav-links a:hover {
    color: var(--accent);
  }
  
  .site-footer {
    padding: 40px 0;
    text-align: center;
    color: var(--fg-muted);
    border-top: 1px solid var(--border);
    margin-top: 80px;
  }
</style>
