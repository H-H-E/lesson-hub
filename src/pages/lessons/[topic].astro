---
import Layout from '../../layouts/Layout.astro';

// Get all generated lessons from workspace
const workspacePath = '../../workspace/';
const docsPath = '../../docs/';

export function getStaticPaths() {
  const lessonData = [
    {
      grade: 1,
      module: 1,
      topic: "Living Things",
      status: "complete",
      score: 85,
      phases: { research: 3, design: 10, create: 6, evaluate: 4, test: 4 }
    }
  ];
  
  return lessonData.map(lesson => ({
    params: { 
      topic: lesson.topic.toLowerCase().replace(/[^a-z0-9]/g, '-'),
      grade: String(lesson.grade)
    },
    props: { lesson }
  }));
}

const { grade, topic } = Astro.params;
const { lesson } = Astro.props;

if (!lesson) {
  return Astro.redirect('/lessons');
}
---

<Layout title={`${topic} - Grade ${grade}`}>
  <main class="lesson-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/lessons">← Back to Lessons</a>
      </nav>
      
      <header class="lesson-header">
        <div class="grade-badge">Grade {grade}</div>
        <h1>{topic}</h1>
        <div class="lesson-meta">
          <span class="status complete">✓ Complete</span>
          <span class="score">Score: {lesson.score}%</span>
        </div>
      </header>
      
      <!-- Pipeline Progress -->
      <section class="pipeline-progress">
        <h2>Pipeline Progress</h2>
        <div class="phases-grid">
          <div class="phase complete">
            <span class="phase-num">1</span>
            <span class="phase-name">Research</span>
            <span class="phase-count">{lesson.phases.research}/3</span>
          </div>
          <div class="phase complete">
            <span class="phase-num">2</span>
            <span class="phase-name">Design</span>
            <span class="phase-count">{lesson.phases.design}/10</span>
          </div>
          <div class="phase complete">
            <span class="phase-num">3</span>
            <span class="phase-name">Create</span>
            <span class="phase-count">{lesson.phases.create}/6</span>
          </div>
          <div class="phase complete">
            <span class="phase-num">4</span>
            <span class="phase-name">Evaluate</span>
            <span class="phase-count">{lesson.phases.evaluate}/4</span>
          </div>
          <div class="phase complete">
            <span class="phase-num">5</span>
            <span class="phase-name">Test/QA</span>
            <span class="phase-count">{lesson.phases.test}/4</span>
          </div>
        </div>
      </section>
      
      <!-- Lesson Content Preview -->
      <section class="lesson-preview">
        <h2>Lesson Components</h2>
        
        <div class="components-grid">
          <div class="component">
            <div class="component-icon">🎯</div>
            <h3>Objectives</h3>
            <p>SMART learning objectives aligned to BC + CSTA standards</p>
          </div>
          
          <div class="component">
            <div class="component-icon">📚</div>
            <h3>Materials</h3>
            <p>Complete materials list for teachers and students</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🎭</div>
            <h3>Hook</h3>
            <p>Engaging opening activity to spark curiosity</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🔬</div>
            <h3>Activities</h3>
            <p>Lesson sequence: Explore, Discover, Create, Check</p>
          </div>
          
          <div class="component">
            <div class="component-icon">♿</div>
            <h3>Differentiation</h3>
            <p>3-level scaffolding: Support, Guided, Extension</p>
          </div>
          
          <div class="component">
            <div class="component-icon">📝</div>
            <h3>Assessment</h3>
            <p>Formative + summative assessments with rubrics</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🌍</div>
            <h3>Systems Literacy</h3>
            <p>Connection to vision: "You are not an atom..."</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🏛️</div>
            <h3>First Peoples</h3>
            <p>Indigenous perspectives and principles</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🎨</div>
            <h3>Cross-Curricular</h3>
            <p>Connections to Math, LA, Arts, Social Studies</p>
          </div>
          
          <div class="component">
            <div class="component-icon">💼</div>
            <h3>Careers</h3>
            <p>Real-world career connections</p>
          </div>
          
          <div class="component">
            <div class="component-icon">👨‍🏫</div>
            <h3>Teacher Notes</h3>
            <p>Timing guide, tips, common questions</p>
          </div>
          
          <div class="component">
            <div class="component-icon">📔</div>
            <h3>Student Journal</h3>
            <p>Explorer's Journal prompts</p>
          </div>
          
          <div class="component">
            <div class="component-icon">👨‍👩‍👧</div>
            <h3>Parent Guide</h3>
            <p>Take-home resources for families</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🎮</div>
            <h3>Simulation</h3>
            <p>Interactive p5.js code</p>
          </div>
          
          <div class="component">
            <div class="component-icon">🚀</div>
            <h3>Extensions</h3>
            <p>Enrichment activities for deeper learning</p>
          </div>
        </div>
      </section>
      
      <!-- View Full Lesson -->
      <section class="view-cta">
        <a href={`/docs/LESSON-GRADE${grade}-MODULE${lesson.module}.md`} class="btn" target="_blank">
          View Full Lesson →
        </a>
      </section>
    </div>
  </main>
</Layout>

<style>
  .lesson-page {
    padding: 40px 0 80px;
  }
  
  .breadcrumb {
    margin-bottom: 30px;
  }
  
  .breadcrumb a {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }
  
  .lesson-header {
    margin-bottom: 50px;
  }
  
  .grade-badge {
    display: inline-block;
    padding: 6px 14px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }
  
  .lesson-header h1 {
    margin-bottom: 16px;
  }
  
  .lesson-meta {
    display: flex;
    gap: 20px;
  }
  
  .status {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  
  .status.complete {
    background: rgba(0, 255, 136, 0.1);
    color: var(--accent-2);
  }
  
  .score {
    color: var(--fg-muted);
  }
  
  /* Pipeline */
  .pipeline-progress {
    margin-bottom: 60px;
  }
  
  .pipeline-progress h2 {
    margin-bottom: 24px;
  }
  
  .phases-grid {
    display: flex;
    gap: 16px;
    overflow-x: auto;
  }
  
  .phase {
    flex: 1;
    min-width: 120px;
    background: var(--bg-elevated);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    text-align: center;
  }
  
  .phase.complete {
    border-color: var(--accent-2);
  }
  
  .phase-num {
    display: block;
    width: 28px;
    height: 28px;
    background: var(--accent-2);
    color: var(--bg);
    border-radius: 50%;
    margin: 0 auto 12px;
    font-weight: 700;
    line-height: 28px;
  }
  
  .phase-name {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
  }
  
  .phase-count {
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  
  /* Components */
  .lesson-preview h2 {
    margin-bottom: 24px;
  }
  
  .components-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }
  
  .component {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: all var(--transition);
  }
  
  .component:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  
  .component-icon {
    font-size: 1.5rem;
    margin-bottom: 12px;
  }
  
  .component h3 {
    font-size: 1rem;
    margin-bottom: 8px;
  }
  
  .component p {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
  
  /* CTA */
  .view-cta {
    margin-top: 60px;
    text-align: center;
  }
</style>
