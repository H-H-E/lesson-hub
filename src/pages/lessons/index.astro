---
import Layout from '../../layouts/Layout.astro';

// Dynamic lesson data - would fetch from API in production
const generatedLessons = [
  { grade: 1, module: 1, topic: 'Living Things', status: 'complete', score: 85 },
  { grade: 1, module: 2, topic: 'Matter', status: 'complete', score: 88 },
  { grade: 2, module: 1, topic: 'Life Cycles', status: 'complete', score: 82 },
];

// Fallback for grades without generated lessons
const allGrades = [
  { level: 1, title: "Grade 1", topics: ["Living Things", "Matter", "Light & Shadow", "Sky Patterns", "Sound", "Sorting"] },
  { level: 2, title: "Grade 2", topics: ["Life Cycles", "Properties of Matter", "Weather", "Position & Motion", "Growth", "Air"] },
  { level: 3, title: "Grade 3", topics: ["Biodiversity", "Forces", "Matter", "Climate", "Rocks", "Systems"] },
  { level: 4, title: "Grade 4", topics: ["Senses", "Light", "Sound", "Energy", "Ecosystems", "Habitats"] },
  { level: 5, title: "Grade 5", topics: ["Body Systems", "Matter", "Earth Systems", "Chemical", "Space", "Sustainability"] },
  { level: 6, title: "Grade 6", topics: ["Cells", "Electricity", "Chemistry", "Ecosystems", "Space", "Water"] },
  { level: 7, title: "Grade 7", topics: ["Evolution", "Chemical Reactions", "Earth History", "Diversity", "Interactions", "Resources"] },
];

// Grade colors for visual distinction
const gradeColors = {
  1: { primary: '#00e5cc', secondary: '#00b8d4', glow: 'rgba(0, 229, 204, 0.15)' },
  2: { primary: '#7c3aed', secondary: '#a855f7', glow: 'rgba(124, 58, 237, 0.15)' },
  3: { primary: '#f97316', secondary: '#fb923c', glow: 'rgba(249, 115, 22, 0.15)' },
  4: { primary: '#10b981', secondary: '#34d399', glow: 'rgba(16, 185, 129, 0.15)' },
  5: { primary: '#ef4444', secondary: '#f87171', glow: 'rgba(239, 68, 68, 0.15)' },
  6: { primary: '#3b82f6', secondary: '#60a5fa', glow: 'rgba(59, 130, 246, 0.15)' },
  7: { primary: '#ec4899', secondary: '#f472b6', glow: 'rgba(236, 72, 153, 0.15)' },
};
---

<Layout title="Lessons">
  <main class="lessons-page">
    <header class="page-header">
      <div class="header-bg"></div>
      <div class="container">
        <div class="header-content" data-animate>
          <h1>
            <span class="title-icon">📚</span>
            Lessons
          </h1>
          <p>Explore our K-7 curriculum aligned with BC Science and CSTA Standards. Click on any topic to view the full lesson.</p>
        </div>
        
        <div class="header-stats" data-animate>
          <div class="header-stat">
            <span class="stat-num">7</span>
            <span class="stat-text">Grade Levels</span>
          </div>
          <div class="header-stat">
            <span class="stat-num">42</span>
            <span class="stat-text">Topics</span>
          </div>
          <div class="header-stat">
            <span class="stat-num">252</span>
            <span class="stat-text">Lesson Components</span>
          </div>
        </div>
      </div>
    </header>
    
    <section class="grades-section">
      <div class="container">
        <div class="grades-grid">
          {allGrades.map((grade, index) => {
            const colors = gradeColors[grade.level];
            const isGenerated = generatedLessons.some(g => g.grade === grade.level);
            const completedTopics = grade.topics.filter(topic => 
              generatedLessons.some(l => l.topic === topic)
            ).length;
            
            return (
              <article 
                class="grade-card" 
                data-animate 
                style={`--accent: ${colors.primary}; --accent-glow: ${colors.glow}`}
              >
                <header class="grade-header">
                  <div class="grade-badge" style={`background: linear-gradient(135deg, ${colors.primary}, ${colors.secondary})`}>
                    G{grade.level}
                  </div>
                  <h2>{grade.title}</h2>
                </header>
                
                <div class="grade-meta">
                  <span class="meta-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M8 1V15M1 8H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    {grade.topics.length} Topics
                  </span>
                  {isGenerated && (
                    <span class="meta-item generated">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 8L6.5 11.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {completedTopics} Generated
                    </span>
                  )}
                </div>
                
                <ul class="topics-list">
                  {grade.topics.map((topic, topicIndex) => {
                    const lesson = generatedLessons.find(l => l.topic === topic);
                    const isComplete = !!lesson;
                    
                    return (
                      <li>
                        <a 
                          href={isComplete ? `/lessons/${topic.toLowerCase().replace(/[^a-z0-9]/g, '-')}` : '#'} 
                          class={`topic-link ${isComplete ? 'complete' : 'pending'}`}
                          style={`--delay: ${topicIndex * 30}ms`}
                        >
                          <span class="topic-indicator">
                            {isComplete ? (
                              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M2.5 7L5.5 10L11.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            ) : (
                              <span class="pending-dot"></span>
                            )}
                          </span>
                          <span class="topic-name">{topic}</span>
                          {isComplete && lesson && (
                            <span class="topic-score" style={`color: ${colors.primary}`}>
                              {lesson.score}%
                            </span>
                          )}
                        </a>
                      </li>
                    );
                  })}
                </ul>
                
                <footer class="grade-footer">
                  <a 
                    href={isGenerated ? `/lessons/grade-${grade.level}` : '#'} 
                    class="grade-action"
                    style={!isGenerated ? 'opacity: 0.5; pointer-events: none;' : ''}
                  >
                    View Grade {grade.level} 
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </footer>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Animate cards on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  
  document.querySelectorAll('.grade-card[data-animate]').forEach(card => {
    observer.observe(card);
  });
  
  // Animate header stats
  const headerObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        
        // Animate numbers
        const nums = entry.target.querySelectorAll('.stat-num');
        nums.forEach(num => {
          const target = parseInt(num.textContent || '0', 10);
          let current = 0;
          const increment = target / 30;
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              num.textContent = String(target);
              clearInterval(timer);
            } else {
              num.textContent = String(Math.floor(current));
            }
          }, 30);
        });
        
        headerObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  
  const headerStats = document.querySelector('.header-stats');
  if (headerStats) headerObserver.observe(headerStats);
</script>

<style>
  .lessons-page {
    padding-bottom: var(--space-3xl);
  }
  
  /* Page Header */
  .page-header {
    position: relative;
    padding: 140px 0 60px;
    overflow: hidden;
  }
  
  .header-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 100% 60% at 50% -20%, rgba(0, 229, 204, 0.1) 0%, transparent 50%),
      var(--bg);
    z-index: -1;
  }
  
  .header-content {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  
  .header-content h1 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }
  
  .title-icon {
    font-size: 2.5rem;
  }
  
  .header-content p {
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
  }
  
  .header-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }
  
  .header-stat {
    text-align: center;
  }
  
  .stat-num {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: var(--space-xs);
  }
  
  .stat-text {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  
  /* Grades Section */
  .grades-section {
    padding: var(--space-xl) 0;
  }
  
  .grades-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
  }
  
  /* Grade Card */
  .grade-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }
  
  .grade-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3), 0 0 0 1px var(--accent-glow);
  }
  
  .grade-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: linear-gradient(135deg, var(--accent-glow), transparent);
    border-bottom: 1px solid var(--border-subtle);
  }
  
  .grade-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--bg);
  }
  
  .grade-header h2 {
    font-size: 1.5rem;
    color: var(--fg-primary);
  }
  
  .grade-meta {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  
  .meta-item.generated {
    color: var(--accent-secondary);
  }
  
  .topics-list {
    list-style: none;
    padding: var(--space-md) var(--space-lg);
  }
  
  .topics-list li {
    margin-bottom: var(--space-xs);
  }
  
  .topic-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    color: var(--fg-secondary);
    font-weight: 500;
    transition: all var(--transition-base);
    transition-delay: var(--delay, 0ms);
  }
  
  .topic-link:hover:not([href="#"]) {
    background: var(--bg-hover);
    color: var(--fg-primary);
  }
  
  .topic-link.complete {
    color: var(--fg-primary);
  }
  
  .topic-link.pending {
    opacity: 0.6;
  }
  
  .topic-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  
  .topic-indicator svg {
    color: var(--accent-secondary);
  }
  
  .pending-dot {
    width: 6px;
    height: 6px;
    background: var(--fg-muted);
    border-radius: 50%;
  }
  
  .topic-name {
    flex: 1;
  }
  
  .topic-score {
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-mono, monospace);
  }
  
  .grade-footer {
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-base);
  }
  
  .grade-action {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    color: var(--accent-primary);
    font-weight: 500;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }
  
  .grade-action:hover {
    background: var(--accent-glow);
  }
  
  .grade-action svg {
    transition: transform var(--transition-base);
  }
  
  .grade-action:hover svg {
    transform: translateX(4px);
  }
  
  /* Animations */
  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .header-stats[data-animate] {
    transition-delay: 0.2s;
  }
  
  .grade-card[data-animate] {
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  
  /* Stagger animation for cards */
  .grades-grid .grade-card:nth-child(1) { transition-delay: 0ms; }
  .grades-grid .grade-card:nth-child(2) { transition-delay: 50ms; }
  .grades-grid .grade-card:nth-child(3) { transition-delay: 100ms; }
  .grades-grid .grade-card:nth-child(4) { transition-delay: 150ms; }
  .grades-grid .grade-card:nth-child(5) { transition-delay: 200ms; }
  .grades-grid .grade-card:nth-child(6) { transition-delay: 250ms; }
  .grades-grid .grade-card:nth-child(7) { transition-delay: 300ms; }
  
  /* Responsive */
  @media (max-width: 768px) {
    .page-header {
      padding: 100px 0 40px;
    }
    
    .header-stats {
      gap: var(--space-xl);
    }
    
    .stat-num {
      font-size: 2rem;
    }
    
    .grades-grid {
      grid-template-columns: 1fr;
    }
    
    .grade-card:hover {
      transform: translateY(-2px);
    }
  }
</style>
