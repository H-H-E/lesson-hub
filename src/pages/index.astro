          </div>
          <div class="stat-card" data-animate>
            <div class="stat-icon">🤖</div>
            <div class="stat-value" data-count="27">0</div>
            <div class="stat-label">AI Agents</div>
          </div>
          <div class="stat-card" data-animate>
            <div class="stat-icon">✓</div>
            <div class="stat-value"><span data-count="100">0</span>%</div>
