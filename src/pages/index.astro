            <div class="stat-icon">�🎓</div>
            <div class="stat-value" data-count="7">0</div>
            <div class="stat-label">Grade Levels</div>
          </div>
          <div class="stat-card" data-animate>
            <div class="stat-icon">�📖</div>
            <div class="stat-value" data-count="42">0</div>
