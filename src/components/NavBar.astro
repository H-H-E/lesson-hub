---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', icon: 'home' },
  { href: '/lessons', label: 'Lessons', icon: 'book' },
  { href: '/dashboard', label: 'Dashboard', icon: 'chart' },
];

const icons: Record<string, string> = {
  home: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  book: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>`,
  chart: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
};
---

<header class="navbar">
  <nav class="nav-container">
    <a href="/" class="logo">
      <span class="logo-icon">🌱</span>
      <span class="logo-text">Lesson Hub</span>
    </a>
    
    <div class="nav-menu">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class={`nav-link ${currentPath === item.href ? 'active' : ''}`}
          data-icon={item.icon}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
          <span>{item.label}</span>
        </a>
      ))}
    </div>
    
    <div class="nav-actions">
      <button class="search-trigger" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      
      <button class="theme-toggle" aria-label="Toggle theme">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  
  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    height: 70px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  
  .logo:hover {
    opacity: 0.8;
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    color: var(--fg-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  
  .nav-link svg {
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .nav-link:hover {
    color: var(--fg);
    background: var(--bg-hover);
  }
  
  .nav-link:hover svg {
    opacity: 1;
  }
  
  .nav-link.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  
  .nav-link.active svg {
    opacity: 1;
  }
  
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .search-trigger,
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .search-trigger:hover,
  .theme-toggle:hover {
    color: var(--fg);
    border-color: var(--accent);
    background: var(--bg-hover);
  }
  
  @media (max-width: 640px) {
    .nav-link span {
      display: none;
    }
    
    .nav-link {
      padding: 10px;
    }
  }
</style>
